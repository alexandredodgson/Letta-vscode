{
  "name": "letta-code-vscode",
  "displayName": "Letta Code",
  "description": "Chat with Letta agents from VSCode with persistent memory.",
  "version": "0.1.0",
  "publisher": "letta",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Language"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "letta-code-sidebar",
          "title": "Letta Code",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "letta-code-sidebar": [
        {
          "type": "webview",
          "id": "letta-code.chatView",
          "name": "Letta Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "letta-code.focus",
        "title": "Letta: Focus Chat"
      },
      {
        "command": "letta-code.restart",
        "title": "Letta: Restart Session"
      }
    ],
    "keybindings": [
      {
        "command": "letta-code.focus",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      }
    ],
    "configuration": {
      "title": "Letta Code",
      "properties": {
        "letta-code.model": {
          "type": "string",
          "default": "claude-sonnet-4.5",
          "description": "The Letta model to use."
        },
        "letta-code.permissionMode": {
          "type": "string",
          "enum": ["default", "acceptEdits", "plan", "bypassPermissions"],
          "default": "default",
          "description": "Letta permission mode."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./ && esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "tsc -p ./ -w & esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --watch",
    "package": "pnpm run build && vsce package --no-dependencies",
    "build": "pnpm run compile && pnpm run build-webview",
    "build-webview": "cd webview-ui && pnpm install && pnpm run build",
    "lint": "eslint src --ext ts",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.103.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "eslint": "^9.13.0",
    "@vscode/vsce": "^3.2.1"
  },
  "dependencies": {
    "events": "^3.3.0"
  }
}
